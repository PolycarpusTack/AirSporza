# E2E build profile: FLAG-ON (ops-e2e v1 — A-5-T0).
# Consumed by `vite build --mode e2e-on`. TD-27: VITE_OPS_REDESIGN is build-time
# only, so each flag state needs its own build — this is the ON build.
# VITE_API_URL=/api makes API calls SAME-ORIGIN so Playwright route interception
# needs no CORS handling (the real backend is never contacted in e2e).
# NOTE: values here must OVERRIDE the developer's local .env (loaded in all modes).
VITE_OPS_REDESIGN=true
VITE_API_URL=/api

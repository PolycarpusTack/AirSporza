generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContractStatus {
  valid
  expiring
  draft
  none
}

enum EventStatus {
  draft
  ready
  approved
  published
  live
  completed
  cancelled
}

enum Role {
  planner
  sports
  contracts
  admin
}

enum SettingScopeKind {
  global
  role
  user
  user_role
}

enum StageType {
  LEAGUE
  GROUP
  KNOCKOUT
  QUALIFIER
  TOURNAMENT_MAIN
}

enum SchedulingMode {
  FIXED
  FLOATING
  WINDOW
}

// =============================================================================
// MULTI-TENANCY
// =============================================================================

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation arrays for all tenant-scoped models
  users                  User[]
  sports                 Sport[]
  competitions           Competition[]
  events                 Event[]
  techPlans              TechPlan[]
  contracts              Contract[]
  encoders               Encoder[]
  encoderLocks           EncoderLock[]
  notifications          Notification[]
  savedViews             SavedView[]
  resources              Resource[]
  resourceAssignments    ResourceAssignment[]
  crewMembers            CrewMember[]
  crewTemplates          CrewTemplate[]
  auditLogs              AuditLog[]
  appSettings            AppSetting[]
  webhookEndpoints       WebhookEndpoint[]
  webhookDeliveries      WebhookDelivery[]
  fieldDefinitions       FieldDefinition[]
  dropdownLists          DropdownList[]
  dropdownOptions        DropdownOption[]
  customFieldValues      CustomFieldValue[]
  mandatoryFieldConfigs  MandatoryFieldConfig[]
  importSources          ImportSource[]
  importJobs             ImportJob[]
  importRecords          ImportRecord[]
  importSourceLinks      ImportSourceLink[]
  mergeCandidates        MergeCandidate[]
  importDeadLetters      ImportDeadLetter[]
  importRateLimits       ImportRateLimit[]
  fieldProvenances       FieldProvenance[]
  canonicalTeams         CanonicalTeam[]
  canonicalCompetitions  CanonicalCompetition[]
  canonicalVenues        CanonicalVenue[]
  teamAliases            TeamAlias[]
  competitionAliases     CompetitionAlias[]
  venueAliases           VenueAlias[]
  syncHistories          SyncHistory[]
  importSchedules        ImportSchedule[]
  venues                 Venue[]
  teams                  Team[]
  courts                 Court[]
  seasons                Season[]
  stages                 Stage[]
  rounds                 Round[]
  channels               Channel[]
  broadcastSlots         BroadcastSlot[]
  scheduleDrafts         ScheduleDraft[]
  scheduleVersions       ScheduleVersion[]
  rightsPolicies         RightsPolicy[]
  runLedgerEntries       RunLedger[]
  outboxEvents           OutboxEvent[]
  cascadeEstimates       CascadeEstimate[]
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  avatar        String?
  role          Role     @default(planner)
  externalId    String?  @unique
  tenantId      String   @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  events            Event[]
  techPlans         TechPlan[]
  appSettings       AppSetting[]
  encoderLocks      EncoderLock[]
  fieldDefinitions  FieldDefinition[]
  webhookEndpoints  WebhookEndpoint[]
  notifications     Notification[]
  savedViews        SavedView[]
  crewTemplates     CrewTemplate[] @relation("UserCrewTemplates")

  @@index([email])
  @@index([externalId])
  @@index([tenantId])
}

model Sport {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  icon        String
  federation  String
  tenantId    String        @db.Uuid
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant                Tenant       @relation(fields: [tenantId], references: [id])
  competitions          Competition[]
  events                Event[]
  canonicalTeams        CanonicalTeam[]
  canonicalCompetitions CanonicalCompetition[]
  mandatoryFieldConfig  MandatoryFieldConfig?

  @@index([tenantId])
}

model Competition {
  id        Int       @id @default(autoincrement())
  sportId   Int
  name      String
  matches   Int
  season    String
  tenantId  String    @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  sport      Sport        @relation(fields: [sportId], references: [id], onDelete: Cascade)
  events     Event[]
  contracts       Contract[]
  seasons         Season[]
  rightsPolicies  RightsPolicy[]

  @@unique([sportId, name, season])
  @@index([sportId])
  @@index([tenantId])
}

model Event {
  id                Int       @id @default(autoincrement())
  sportId           Int
  competitionId     Int
  createdById       String?
  tenantId          String    @db.Uuid

  phase             String?
  category          String?
  participants      String
  content           String?

  startDateBE       DateTime
  startTimeBE       String
  startDateOrigin   DateTime?
  startTimeOrigin   String?

  complex           String?
  livestreamDate    DateTime?
  livestreamTime    String?

  linearChannel     String?
  radioChannel      String?
  linearStartTime   String?
  onDemandChannel   String?

  isLive            Boolean   @default(false)
  isDelayedLive     Boolean   @default(false)

  videoRef          String?
  winner            String?
  score             String?
  duration          String?

  customFields      Json      @default("{}")
  status            EventStatus @default(draft)
  seriesId          String?

  venueId           Int?
  seasonId          Int?
  stageId           Int?
  roundId           Int?
  schedulingMode    SchedulingMode @default(FIXED)
  sportMetadata     Json           @default("{}")
  externalRefs      Json           @default("{}")

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  sport             Sport         @relation(fields: [sportId], references: [id])
  competition       Competition   @relation(fields: [competitionId], references: [id])
  createdBy         User?         @relation(fields: [createdById], references: [id])
  venue             Venue?        @relation(fields: [venueId], references: [id])
  season            Season?       @relation(fields: [seasonId], references: [id])
  stage             Stage?        @relation(fields: [stageId], references: [id])
  round             Round?        @relation(fields: [roundId], references: [id])
  techPlans         TechPlan[]
  broadcastSlots    BroadcastSlot[]
  cascadeEstimates  CascadeEstimate[]

  @@index([sportId])
  @@index([competitionId])
  @@index([startDateBE])
  @@index([linearChannel])
  @@index([status])
  @@index([seriesId])
  @@index([venueId])
  @@index([seasonId])
  @@index([stageId])
  @@index([roundId])
  @@index([tenantId])
}

model TechPlan {
  id            Int       @id @default(autoincrement())
  eventId       Int
  planType      String
  crew          Json      @default("{}")
  isLivestream  Boolean   @default(false)
  customFields  Json      @default("[]")
  createdById   String?
  tenantId      String    @db.Uuid

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy     User?     @relation(fields: [createdById], references: [id])
  encoderLocks  EncoderLock[]
  assignments   ResourceAssignment[]

  @@index([eventId])
  @@index([tenantId])
}

model Contract {
  id              Int             @id @default(autoincrement())
  competitionId   Int
  status          ContractStatus  @default(none)
  tenantId        String          @db.Uuid

  validFrom       DateTime?
  validUntil      DateTime?

  linearRights    Boolean         @default(false)
  maxRights       Boolean         @default(false)
  radioRights     Boolean         @default(false)
  sublicensing    Boolean         @default(false)

  geoRestriction  String?
  fee             String?
  notes           String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  competition     Competition     @relation(fields: [competitionId], references: [id])

  @@index([competitionId])
  @@index([status])
  @@index([validUntil])
  @@index([tenantId])
}

model Encoder {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  location    String?
  isActive    Boolean   @default(true)
  notes       String?
  tenantId    String    @db.Uuid

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?
  action      String
  entityType  String
  entityId    String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  tenantId    String    @db.Uuid

  createdAt   DateTime  @default(now())

  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([tenantId])
}

model AppSetting {
  id          String           @id @default(uuid())
  key         String
  scopeKind   SettingScopeKind
  scopeId     String
  userId      String?
  value       Json
  tenantId    String           @db.Uuid
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([key, scopeKind, scopeId])
  @@index([scopeKind, scopeId])
  @@index([userId])
  @@index([tenantId])
}

// =============================================================================
// FIELD ENGINE
// =============================================================================

enum FieldType {
  text
  number
  date
  time
  dropdown
  checkbox
  textarea
}

enum FieldSection {
  event
  crew
  contract
}

model FieldDefinition {
  id               String        @id
  name             String        @unique
  label            String
  fieldType        FieldType
  section          FieldSection
  required         Boolean       @default(false)
  sortOrder        Int           @default(0)
  options          String[]
  dropdownSourceId String?
  defaultValue     String?
  conditionalRules Json          @default("[]")
  visibleByRoles   Role[]
  isSystem         Boolean       @default(false)
  isCustom         Boolean       @default(true)
  visible          Boolean       @default(true)
  createdById      String?
  tenantId         String        @db.Uuid

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  dropdownSource   DropdownList?          @relation(fields: [dropdownSourceId], references: [id])
  createdBy        User?                  @relation(fields: [createdById], references: [id])
  customValues     CustomFieldValue[]
  mandatoryConfigs MandatoryFieldConfig[]

  @@index([section, sortOrder])
  @@index([tenantId])
}

model CustomFieldValue {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  fieldId     String
  fieldValue  String
  tenantId    String   @db.Uuid

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  field       FieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, fieldId])
  @@index([entityType, entityId])
  @@index([tenantId])
}

model DropdownList {
  id          String   @id
  name        String
  description String?
  managedBy   Role     @default(admin)
  tenantId    String   @db.Uuid
  createdAt   DateTime @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  options     DropdownOption[]
  fields      FieldDefinition[]

  @@index([tenantId])
}

model DropdownOption {
  id          String   @id @default(uuid())
  listId      String
  value       String
  label       String
  parentId    String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  metadata    Json     @default("{}")
  tenantId    String   @db.Uuid
  createdAt   DateTime @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  list        DropdownList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  parent      DropdownOption? @relation("DropdownOptionChildren", fields: [parentId], references: [id])
  children    DropdownOption[] @relation("DropdownOptionChildren")

  @@unique([listId, value])
  @@index([listId, sortOrder])
  @@index([tenantId])
}

model MandatoryFieldConfig {
  id                  String   @id @default(uuid())
  sportId             Int      @unique
  fieldIds            String[]
  conditionalRequired Json     @default("[]")
  tenantId            String   @db.Uuid
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  sport               Sport             @relation(fields: [sportId], references: [id], onDelete: Cascade)
  fields              FieldDefinition[]

  @@index([sportId])
  @@index([tenantId])
}

// =============================================================================
// IMPORT SYSTEM
// =============================================================================

enum ImportSourceKind {
  api
  file
}

enum ImportJobStatus {
  queued
  running
  completed
  failed
  partial
}

enum ImportJobMode {
  full
  incremental
  backfill
}

enum ValidationStatus {
  pending
  valid
  invalid
  quarantined
}

enum MergeCandidateStatus {
  pending
  approved_merge
  create_new
  ignored
}

enum SyncStatus {
  success
  failed
  partial
}

model ImportSource {
  id                  String            @id @default(uuid())
  code                String            @unique
  name                String
  kind                ImportSourceKind
  priority            Int               @default(100)
  isEnabled           Boolean           @default(true)
  configJson          Json              @default("{}")
  rateLimitPerMinute  Int?
  rateLimitPerDay     Int?
  lastFetchAt         DateTime?
  tenantId            String            @db.Uuid
  createdAt           DateTime          @default(now())

  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  jobs                ImportJob[]
  records             ImportRecord[]
  sourceLinks         ImportSourceLink[]
  deadLetters         ImportDeadLetter[]
  rateLimits          ImportRateLimit?
  teamAliases         TeamAlias[]
  competitionAliases  CompetitionAlias[]
  venueAliases        VenueAlias[]
  canonicalTeams      CanonicalTeam[]   @relation("CanonicalTeamSource")
  canonicalCompetitions CanonicalCompetition[] @relation("CanonicalCompetitionSource")
  canonicalVenues     CanonicalVenue[]  @relation("CanonicalVenueSource")
  schedule            ImportSchedule?

  @@index([tenantId])
}

model ImportJob {
  id              String          @id @default(uuid())
  sourceId        String
  entityScope     String
  mode            ImportJobMode
  status          ImportJobStatus @default(queued)
  idempotencyKey  String?         @unique
  cursor          String?
  startedAt       DateTime?
  finishedAt      DateTime?
  statsJson       Json            @default("{}")
  errorLog        String?
  tenantId        String          @db.Uuid
  createdAt       DateTime        @default(now())

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  source          ImportSource    @relation(fields: [sourceId], references: [id])
  records         ImportRecord[]
  deadLetters     ImportDeadLetter[]

  @@index([sourceId])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId])
}

model ImportRecord {
  id                String            @id @default(uuid())
  jobId             String
  sourceId          String
  sourceRecordId    String
  sourceUpdatedAt   DateTime?
  entityType        String
  payloadJson       Json
  payloadHash       String
  normalizedJson    Json?
  normalizedHash    String?
  validationStatus  ValidationStatus  @default(pending)
  validationErrors  Json              @default("[]")
  isSuperseded      Boolean           @default(false)
  supersededByJobId String?
  tenantId          String            @db.Uuid
  createdAt         DateTime          @default(now())

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  job               ImportJob         @relation(fields: [jobId], references: [id])
  source            ImportSource      @relation(fields: [sourceId], references: [id])
  mergeCandidates   MergeCandidate[]

  @@unique([sourceId, sourceRecordId, entityType])
  @@index([jobId])
  @@index([validationStatus])
  @@index([entityType])
  @@index([tenantId])
}

model ImportSourceLink {
  id              String    @id @default(uuid())
  sourceId        String
  sourceRecordId  String
  entityType      String
  entityId        String
  confidence      Decimal   @db.Decimal(5, 2)
  matchMethod     String
  isManual        Boolean   @default(false)
  tenantId        String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  source          ImportSource @relation(fields: [sourceId], references: [id])

  @@unique([sourceId, sourceRecordId, entityType])
  @@index([entityType, entityId])
  @@index([entityType, entityId, confidence])
  @@index([tenantId])
}

model MergeCandidate {
  id                  String                @id @default(uuid())
  importRecordId      String
  entityType          String
  suggestedEntityId  String?
  confidence          Decimal               @db.Decimal(5, 2)
  reasonCodes         Json                  @default("[]")
  status              MergeCandidateStatus  @default(pending)
  reviewedBy          String?
  reviewedAt          DateTime?
  tenantId            String                @db.Uuid
  createdAt           DateTime              @default(now())

  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  importRecord        ImportRecord @relation(fields: [importRecordId], references: [id])

  @@index([entityType, status])
  @@index([tenantId])
}

model ImportDeadLetter {
  id              String    @id @default(uuid())
  jobId           String?
  sourceId        String
  sourceRecordId  String?
  rawPayload      Json
  errorMessage    String
  errorType       String
  retryCount      Int       @default(0)
  lastRetryAt     DateTime?
  nextRetryAt     DateTime?
  resolvedAt      DateTime?
  tenantId        String    @db.Uuid
  createdAt       DateTime  @default(now())

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  job             ImportJob?   @relation(fields: [jobId], references: [id])
  source          ImportSource @relation(fields: [sourceId], references: [id])

  @@index([nextRetryAt])
  @@index([sourceId, errorType])
  @@index([tenantId])
}

model ImportRateLimit {
  sourceId            String    @id
  requestsThisMinute  Int       @default(0)
  requestsThisDay     Int       @default(0)
  minuteWindowStart   DateTime  @default(now())
  dayWindowStart      DateTime  @default(now())
  lastRequestAt       DateTime?
  tenantId            String    @db.Uuid

  tenant              Tenant       @relation(fields: [tenantId], references: [id])
  source              ImportSource @relation(fields: [sourceId], references: [id])

  @@index([tenantId])
}

model FieldProvenance {
  id              String    @id @default(uuid())
  entityType      String
  entityId        String
  fieldName       String
  sourceId        String
  sourceRecordId  String
  sourceUpdatedAt DateTime?
  tenantId        String    @db.Uuid
  importedAt      DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([entityType, entityId, fieldName])
  @@index([entityType, entityId])
  @@index([tenantId])
}

model CanonicalTeam {
  id              String    @id @default(uuid())
  primaryName     String
  countryCode     String?
  sportId         Int
  logoUrl         String?
  primarySourceId String?
  tenantId        String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  sport           Sport        @relation(fields: [sportId], references: [id])
  primarySource   ImportSource? @relation("CanonicalTeamSource", fields: [primarySourceId], references: [id])
  aliases         TeamAlias[]

  @@unique([sportId, primaryName])
  @@index([tenantId])
}

model CanonicalCompetition {
  id              String    @id @default(uuid())
  primaryName     String
  sportId         Int
  countryCode     String?
  logoUrl         String?
  primarySourceId String?
  tenantId        String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  sport           Sport        @relation(fields: [sportId], references: [id])
  primarySource   ImportSource? @relation("CanonicalCompetitionSource", fields: [primarySourceId], references: [id])
  aliases         CompetitionAlias[]

  @@unique([sportId, primaryName])
  @@index([tenantId])
}

model CanonicalVenue {
  id              String    @id @default(uuid())
  primaryName     String
  city            String?
  countryCode     String?
  capacity        Int?
  primarySourceId String?
  tenantId        String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  primarySource   ImportSource? @relation("CanonicalVenueSource", fields: [primarySourceId], references: [id])
  aliases         VenueAlias[]

  @@unique([primaryName, city])
  @@index([tenantId])
}

model TeamAlias {
  id                String        @id @default(uuid())
  canonicalTeamId   String
  sourceId          String?
  alias             String
  normalizedAlias   String
  tenantId          String        @db.Uuid

  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  canonicalTeam     CanonicalTeam @relation(fields: [canonicalTeamId], references: [id])
  source            ImportSource? @relation(fields: [sourceId], references: [id])

  @@unique([sourceId, normalizedAlias])
  @@index([normalizedAlias])
  @@index([tenantId])
}

model CompetitionAlias {
  id                      String              @id @default(uuid())
  canonicalCompetitionId  String
  sourceId                String?
  alias                   String
  normalizedAlias         String
  tenantId                String              @db.Uuid

  tenant                  Tenant              @relation(fields: [tenantId], references: [id])
  canonicalCompetition    CanonicalCompetition @relation(fields: [canonicalCompetitionId], references: [id])
  source                  ImportSource?       @relation(fields: [sourceId], references: [id])

  @@unique([sourceId, normalizedAlias])
  @@index([normalizedAlias])
  @@index([tenantId])
}

model VenueAlias {
  id                String        @id @default(uuid())
  canonicalVenueId  String
  sourceId          String?
  alias             String
  normalizedAlias   String
  tenantId          String        @db.Uuid

  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  canonicalVenue    CanonicalVenue @relation(fields: [canonicalVenueId], references: [id])
  source            ImportSource? @relation(fields: [sourceId], references: [id])

  @@unique([sourceId, normalizedAlias])
  @@index([normalizedAlias])
  @@index([tenantId])
}

model SyncHistory {
  id                String      @id @default(uuid())
  entityType        String
  entityId          String?
  sourceCode        String
  syncType          String
  triggeredBy       String?
  status            SyncStatus
  recordsProcessed  Int         @default(0)
  recordsCreated    Int         @default(0)
  recordsUpdated    Int         @default(0)
  recordsSkipped    Int         @default(0)
  errorMessage      String?
  tenantId          String      @db.Uuid
  createdAt         DateTime    @default(now())

  tenant            Tenant      @relation(fields: [tenantId], references: [id])

  @@index([entityType, createdAt])
  @@index([triggeredBy])
  @@index([tenantId])
}

model EncoderLock {
  encoderName String   @id
  lockedById  String
  planId      Int
  expiresAt   DateTime
  tenantId    String   @db.Uuid

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  lockedBy    User     @relation(fields: [lockedById], references: [id], onDelete: Cascade)
  plan        TechPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([tenantId])
}

model WebhookEndpoint {
  id          String            @id @default(uuid())
  url         String
  secret      String
  events      String[]
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  createdById String?
  tenantId    String            @db.Uuid

  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  createdBy   User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  deliveries  WebhookDelivery[]

  @@index([isActive])
  @@index([tenantId])
}

model WebhookDelivery {
  id          String    @id @default(uuid())
  webhookId   String
  eventType   String
  payload     Json
  statusCode  Int?
  attempts    Int       @default(0)
  deliveredAt DateTime?
  error       String?
  tenantId    String    @db.Uuid
  createdAt   DateTime  @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  webhook     WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@index([eventType])
  @@index([deliveredAt])
  @@index([tenantId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  body        String?
  entityType  String?
  entityId    String?
  isRead      Boolean  @default(false)
  tenantId    String   @db.Uuid
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@index([tenantId])
}

model SavedView {
  id           String   @id @default(uuid())
  userId       String
  name         String
  context      String
  filterState  Json     @default("{}")
  tenantId     String   @db.Uuid
  createdAt    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, context])
  @@index([tenantId])
}

model ImportSchedule {
  id        String    @id @default(uuid())
  sourceId  String    @unique
  cronExpr  String
  isEnabled Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  tenantId  String    @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  source    ImportSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// =============================================================================
// RESOURCE PLANNING
// =============================================================================

model Resource {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  type        String
  capacity    Int      @default(1)
  isActive    Boolean  @default(true)
  notes       String?
  tenantId    String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  assignments ResourceAssignment[]

  @@index([tenantId])
}

model ResourceAssignment {
  id          Int      @id @default(autoincrement())
  resourceId  Int
  techPlanId  Int
  quantity    Int      @default(1)
  notes       String?
  tenantId    String   @db.Uuid
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  techPlan    TechPlan @relation(fields: [techPlanId], references: [id], onDelete: Cascade)

  @@unique([resourceId, techPlanId])
  @@index([techPlanId])
  @@index([resourceId])
  @@index([tenantId])
}

// =============================================================================
// CREW ROSTER & TEMPLATES
// =============================================================================

model CrewMember {
  id        Int      @id @default(autoincrement())
  name      String
  roles     Json     @default("[]")
  email     String?
  phone     String?
  isActive  Boolean  @default(true)
  tenantId  String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([name])
  @@index([tenantId])
  @@map("crew_members")
}

model CrewTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  planType    String?
  crewData    Json
  createdById String?  @db.VarChar(36)
  isShared    Boolean  @default(false)
  tenantId    String   @db.Uuid
  createdBy   User?    @relation("UserCrewTemplates", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([planType, createdById])
  @@index([tenantId])
  @@map("crew_templates")
}

// =============================================================================
// BROADCAST MIDDLEWARE — VENUE, TEAM, COURT
// =============================================================================

model Venue {
  id        Int      @id @default(autoincrement())
  tenantId  String   @db.Uuid
  name      String
  timezone  String   @default("Europe/Brussels")
  country   String?
  address   String?
  capacity  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  courts    Court[]
  events    Event[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Team {
  id           Int      @id @default(autoincrement())
  tenantId     String   @db.Uuid
  name         String
  shortName    String?
  country      String?
  logoUrl      String?
  externalRefs Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Court {
  id                Int      @id @default(autoincrement())
  tenantId          String   @db.Uuid
  venueId           Int
  name              String
  capacity          Int?
  hasRoof           Boolean  @default(false)
  isShowCourt       Boolean  @default(false)
  broadcastPriority Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  venue             Venue    @relation(fields: [venueId], references: [id])

  @@unique([venueId, name])
  @@index([tenantId])
}

// =============================================================================
// BROADCAST MIDDLEWARE — SEASON, STAGE, ROUND
// =============================================================================

model Season {
  id            Int         @id @default(autoincrement())
  tenantId      String      @db.Uuid
  competitionId Int
  name          String
  startDate     DateTime    @db.Date
  endDate       DateTime    @db.Date
  sportMetadata Json        @default("{}")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  competition   Competition @relation(fields: [competitionId], references: [id])
  stages        Stage[]
  events        Event[]

  @@unique([tenantId, competitionId, name])
  @@index([tenantId])
}

model Stage {
  id               Int       @id @default(autoincrement())
  tenantId         String    @db.Uuid
  seasonId         Int
  name             String
  stageType        StageType
  sortOrder        Int       @default(0)
  advancementRules Json      @default("{}")
  sportMetadata    Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  season           Season    @relation(fields: [seasonId], references: [id])
  rounds           Round[]
  events           Event[]

  @@index([tenantId])
}

model Round {
  id                 Int       @id @default(autoincrement())
  tenantId           String    @db.Uuid
  stageId            Int
  name               String
  roundNumber        Int
  scheduledDateStart DateTime? @db.Date
  scheduledDateEnd   DateTime? @db.Date
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  stage              Stage     @relation(fields: [stageId], references: [id])
  events             Event[]

  @@index([tenantId])
}

// =============================================================================
// BROADCAST MIDDLEWARE — CHANNEL & BROADCAST SLOT
// =============================================================================

enum OverrunStrategy {
  EXTEND
  CONDITIONAL_SWITCH
  HARD_CUT
  SPLIT_SCREEN
}

enum AnchorType {
  FIXED_TIME
  COURT_POSITION
  FOLLOWS_MATCH
  HANDOFF
  NOT_BEFORE
}

enum BroadcastSlotStatus {
  PLANNED
  LIVE
  OVERRUN
  SWITCHED_OUT
  COMPLETED
  VOIDED
}

enum ContentSegment {
  FULL
  CONTINUATION
}

model Channel {
  id                     Int      @id @default(autoincrement())
  tenantId               String   @db.Uuid
  name                   String
  timezone               String   @default("Europe/Brussels")
  broadcastDayStartLocal String   @default("06:00")
  epgConfig              Json     @default("{}")
  color                  String   @default("#3B82F6")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant                 Tenant            @relation(fields: [tenantId], references: [id])
  broadcastSlots         BroadcastSlot[]
  scheduleDrafts         ScheduleDraft[]
  scheduleVersions       ScheduleVersion[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model BroadcastSlot {
  id                         String               @id @default(uuid()) @db.Uuid
  tenantId                   String               @db.Uuid
  channelId                  Int
  eventId                    Int?
  schedulingMode             SchedulingMode       @default(FIXED)
  plannedStartUtc            DateTime?            @db.Timestamptz
  plannedEndUtc              DateTime?            @db.Timestamptz
  estimatedStartUtc          DateTime?            @db.Timestamptz
  estimatedEndUtc            DateTime?            @db.Timestamptz
  earliestStartUtc           DateTime?            @db.Timestamptz
  latestStartUtc             DateTime?            @db.Timestamptz
  actualStartUtc             DateTime?            @db.Timestamptz
  actualEndUtc               DateTime?            @db.Timestamptz
  bufferBeforeMin            Int                  @default(15)
  bufferAfterMin             Int                  @default(25)
  expectedDurationMin        Int?
  overrunStrategy            OverrunStrategy      @default(EXTEND)
  conditionalTriggerUtc      DateTime?            @db.Timestamptz
  conditionalTargetChannelId Int?
  anchorType                 AnchorType           @default(FIXED_TIME)
  coveragePriority           Int                  @default(1)
  fallbackEventId            Int?
  status                     BroadcastSlotStatus  @default(PLANNED)
  contentSegment             ContentSegment       @default(FULL)
  scheduleVersionId          String?              @db.Uuid
  sportMetadata              Json                 @default("{}")
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  tenant                     Tenant               @relation(fields: [tenantId], references: [id])
  channel                    Channel              @relation(fields: [channelId], references: [id])
  event                      Event?               @relation(fields: [eventId], references: [id])
  scheduleVersion            ScheduleVersion?     @relation(fields: [scheduleVersionId], references: [id])
  runLedgerEntries           RunLedger[]

  @@index([tenantId])
  @@index([channelId, plannedStartUtc])
  @@index([eventId])
}

// =============================================================================
// BROADCAST MIDDLEWARE — SCHEDULE DRAFT & VERSION
// =============================================================================

enum DraftStatus {
  EDITING
  VALIDATING
  PUBLISHED
}

model ScheduleDraft {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid
  channelId      Int
  dateRangeStart DateTime    @db.Date
  dateRangeEnd   DateTime    @db.Date
  operations     Json        @default("[]")
  version        Int         @default(1)
  status         DraftStatus @default(EDITING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  channel        Channel     @relation(fields: [channelId], references: [id])
  versions       ScheduleVersion[]

  @@unique([tenantId, channelId, dateRangeStart, dateRangeEnd])
  @@index([tenantId])
}

model ScheduleVersion {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @db.Uuid
  channelId            Int
  draftId              String    @db.Uuid
  versionNumber        Int
  snapshot             Json
  publishedAt          DateTime  @default(now()) @db.Timestamptz
  publishedBy          String
  isEmergency          Boolean   @default(false)
  reasonCode           String?
  acknowledgedWarnings Json      @default("[]")

  tenant               Tenant    @relation(fields: [tenantId], references: [id])
  channel              Channel   @relation(fields: [channelId], references: [id])
  draft                ScheduleDraft @relation(fields: [draftId], references: [id])
  broadcastSlots       BroadcastSlot[]

  @@index([tenantId])
}

// =============================================================================
// BROADCAST MIDDLEWARE — RIGHTS & RUN LEDGER
// =============================================================================

enum CoverageType {
  LIVE
  HIGHLIGHTS
  DELAYED
  CLIP
}

enum Platform {
  LINEAR
  OTT
  SVOD
  AVOD
  PPV
  STREAMING
}

enum RunType {
  LIVE
  CONTINUATION
  TAPE_DELAY
  HIGHLIGHTS
  CLIP
}

enum RunStatus {
  PENDING
  CONFIRMED
  RECONCILED
  DISPUTED
}

model RightsPolicy {
  id                   String       @id @default(uuid()) @db.Uuid
  tenantId             String       @db.Uuid
  competitionId        Int
  seasonId             Int?
  territory            String[]
  platforms            Platform[]
  coverageType         CoverageType @default(LIVE)
  maxLiveRuns          Int?
  maxPickRunsPerRound  Int?
  windowStartUtc       DateTime?    @db.Timestamptz
  windowEndUtc         DateTime?    @db.Timestamptz
  tapeDelayHoursMin    Int?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  tenant               Tenant       @relation(fields: [tenantId], references: [id])
  competition          Competition  @relation(fields: [competitionId], references: [id])

  @@index([tenantId])
}

model RunLedger {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  broadcastSlotId String    @db.Uuid
  eventId         Int
  channelId       Int
  runType         RunType   @default(LIVE)
  parentRunId     String?   @db.Uuid
  startedAtUtc    DateTime? @db.Timestamptz
  endedAtUtc      DateTime? @db.Timestamptz
  durationMin     Int?
  status          RunStatus @default(PENDING)
  createdAt       DateTime  @default(now())

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  broadcastSlot   BroadcastSlot @relation(fields: [broadcastSlotId], references: [id])
  parentRun       RunLedger?    @relation("RunChain", fields: [parentRunId], references: [id])
  childRuns       RunLedger[]   @relation("RunChain")

  @@unique([tenantId, broadcastSlotId, runType])
  @@index([tenantId])
  @@index([eventId])
}

// =============================================================================
// BROADCAST MIDDLEWARE — TRANSACTIONAL OUTBOX
// =============================================================================

enum OutboxPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model OutboxEvent {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @db.Uuid
  eventType      String
  aggregateType  String
  aggregateId    String
  payload        Json
  idempotencyKey String         @unique
  priority       OutboxPriority @default(NORMAL)
  createdAt      DateTime       @default(now()) @db.Timestamptz
  processedAt    DateTime?      @db.Timestamptz
  failedAt       DateTime?      @db.Timestamptz
  retryCount     Int            @default(0)
  maxRetries     Int            @default(5)
  deadLetteredAt DateTime?      @db.Timestamptz

  tenant         Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([processedAt, deadLetteredAt, priority, createdAt])
}

// =============================================================================
// BROADCAST MIDDLEWARE — CASCADE ENGINE
// =============================================================================

model CascadeEstimate {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  eventId            Int
  estimatedStartUtc  DateTime? @db.Timestamptz
  earliestStartUtc   DateTime? @db.Timestamptz
  latestStartUtc     DateTime? @db.Timestamptz
  estDurationShortMin Int?
  estDurationLongMin  Int?
  confidenceScore    Float    @default(0.5)
  inputsUsed         Json     @default("{}")
  computedAt         DateTime @default(now()) @db.Timestamptz

  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  event              Event    @relation(fields: [eventId], references: [id])

  @@unique([tenantId, eventId])
  @@index([tenantId])
}

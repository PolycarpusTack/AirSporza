NODE_ENV=development
PORT=3001

DATABASE_URL="postgresql://sporza:sporza123@localhost:5432/sporza_planner?schema=public"

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_AUTHORIZATION_URL=https://your-idp.com/oauth/authorize
OAUTH_TOKEN_URL=https://your-idp.com/oauth/token
OAUTH_USER_INFO_URL=https://your-idp.com/api/user
OAUTH_CALLBACK_URL=http://localhost:3001/auth/callback

CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Feature flags (backend, build/deploy-time per TD-27; absent/"false" = OFF) ──
# RIGHTS_WINDOWS_ENABLED (EPIC RD): window-aware rights enforcement (checker v2) on
#   draft-validate/publish + /rights/check-slots. OFF = legacy scalar checker, byte-
#   identical to baseline. Only the literal "true" enables. Rollback = redeploy off.
#   Rollout: docs/runbooks/rights-windows.md §Rollout. Staging first; prod stays off.
RIGHTS_WINDOWS_ENABLED=false
# REGULATORY_COMPLIANCE_ENABLED (EPIC RC): stage-4 LISTED_EVENT_FTA check for listed-
#   events free-to-air obligations. OFF = watershed + accessibility only, byte-identical
#   to baseline. Only the literal "true" enables. Rollback = redeploy off.
REGULATORY_COMPLIANCE_ENABLED=false

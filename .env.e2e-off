# E2E build profile: FLAG-OFF (ops-e2e v1 — A-5-T0).
# Consumed by `vite build --mode e2e-off`. TD-27: VITE_OPS_REDESIGN is build-time
# only — this is the OFF build (explicit 'false' so a developer's local .env,
# which Vite loads in every mode, can never leak the flag ON).
VITE_OPS_REDESIGN=false
VITE_API_URL=/api

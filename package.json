{
  "name": "sporza-planner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:on": "playwright test --project=flag-on",
    "test:e2e:off": "playwright test --project=flag-off",
    "e2e:serve:on": "vite build --mode e2e-on --outDir dist-e2e/on && vite preview --outDir dist-e2e/on --port 4181 --strictPort",
    "e2e:serve:off": "vite build --mode e2e-off --outDir dist-e2e/off && vite preview --outDir dist-e2e/off --port 4182 --strictPort",
    "preview": "vite preview",
    "dev:full": "concurrently \"npm run dev\" \"cd backend && npm run dev\" \"cd backend && npm run worker:dev\"",
    "setup:db": "cd backend && npm run db:deploy && npm run db:seed",
    "setup": "npm install && cd backend && npm install && npm run db:generate && npm run db:deploy && npm run db:seed"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^0.576.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^3.2.6"
  }
}
